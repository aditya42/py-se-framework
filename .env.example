# Browser settings
BROWSER=chrome
HEADLESS=true
BASE_URL=
EXPLICIT_WAIT=10
PAGE_LOAD_TIMEOUT=30

# AI is disabled by default. Enable only when an API key is available.
AI_ENABLED=false
AI_PROVIDER=openai
AI_MODEL=gpt-5-mini
OPENAI_API_KEY=

# Safety: suggest_only never writes source files or silently changes locators.
AI_HEALING_MODE=suggest_only
